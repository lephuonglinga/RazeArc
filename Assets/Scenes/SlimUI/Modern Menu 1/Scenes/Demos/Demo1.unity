  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9541d86e2fd84c1d9990edf0852d74ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "You don\u2019t know who built this place, and there\u2019s no one left
    to ask. It\u2019s just a sequence of arenas with enemies waiting, weapons scattered,
    exits always just out of reach. Move, shoot, take what you can, and keep going.
    It doesn\u2019t get easier, only faster. Maybe there\u2019s something at the
    end. Maybe that\u2019s the point.\n\nWelcome to RazeArc. That\u2019s the whole
    game."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 9d24e6b3ecd1d2b479a31d3d0e7b1f9e, type: 2}
  m_sharedMaterial: {fileID: 21148088844906328, guid: 9d24e6b3ecd1d2b479a31d3d0e7b1f9e, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
  m_fontMaterials: []
  m_fontColor32:
